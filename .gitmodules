[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "azr"]
	path = azr
	url = https://github.com/pedrobtz/azr
[submodule "data.sketches"]
	path = data.sketches
	url = https://github.com/pedrobtz/data.sketches
[submodule "imf.data"]
	path = imf.data
	url = https://github.com/pedrobtz/imf.data
[submodule "quak"]
	path = quak
	url = https://github.com/pedrobtz/quak
